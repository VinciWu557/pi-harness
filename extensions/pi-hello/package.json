{
	"name": "@vinciwu557/pi-hello",
	"version": "0.1.0",
	"description": "Pi extension example with greet tool, hello command, and dangerous command interception.",
	"type": "module",
	"license": "MIT",
	"private": false,
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"hello",
		"example"
	],
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
