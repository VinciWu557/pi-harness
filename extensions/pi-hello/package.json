	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.80.3",
		"@types/node": "^26.1.0",
		"typescript": "^5.7.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/VinciWu557/pi-harness",
		"directory": "extensions/pi-hello"
	}
