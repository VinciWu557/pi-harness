{
	"name": "pi-harness",
	"version": "0.1.0",
	"private": true,
	"description": "Monorepo for @vinciwu557 pi extension, skill, prompt, and theme packages.",
	"type": "module",
	"license": "MIT",
	"author": "VinciWu557",
	"repository": {
		"type": "git",
		"url": "https://github.com/VinciWu557/pi-harness"
	},
	"workspaces": [
		"extensions/*",
		"skills/*"
	],
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"check:boundaries": "node ./scripts/check-extension-boundaries.mjs",
		"typecheck": "npm --workspaces --if-present run typecheck",
		"test": "vitest run",
		"check": "npm run lint && npm run format:check && npm run check:boundaries && npm run typecheck && npm test"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.80.3",
		"@eslint/js": "^9.0.0",
		"@types/node": "^26.1.0",
		"eslint": "^9.0.0",
		"globals": "^17.7.0",
		"prettier": "^3.0.0",
		"typebox": "^1.3.3",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.0.0",
		"vitest": "^2.0.0"
	}
}
